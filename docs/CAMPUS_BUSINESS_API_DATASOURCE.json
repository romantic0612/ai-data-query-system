        "metric_name": "指标名称",
        "student_count": "学生人数",
        "unit": "单位"
      },
      "raw_answer": {
        "label_template": "{student_level}{metric_name}",
        "value_field": "student_count",
        "unit_field": "unit"
      }
    },
